# CYNTHERA Environment Variables
# Copy this file to .env and fill in your actual values
# NEVER commit .env to version control

# ─────────────────────────────────────────────
# LLM Configuration
# ─────────────────────────────────────────────
LLM_PROVIDER=google
LLM_MODEL=gemini-1.5-flash
LLM_API_KEY=your-gemini-api-key-here
GEMINI_API_KEY=your-gemini-api-key-here

# ─────────────────────────────────────────────
# NCBI / PubMed (Optional — increases rate limit from 3 to 10 req/s)
# Register at: https://www.ncbi.nlm.nih.gov/account/
# ─────────────────────────────────────────────
NCBI_API_KEY=your-ncbi-api-key-here

# ─────────────────────────────────────────────
# DisGeNET (Optional — gene-disease associations)
# Register at: https://www.disgenet.org/
# ─────────────────────────────────────────────
DISGENET_API_KEY=your-disgenet-api-key-here

# ─────────────────────────────────────────────
# Database (Phase 3+ — PostgreSQL)
# ─────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://cynthera:password@localhost:5432/cynthera

# ─────────────────────────────────────────────
# Cache (Phase 2+ — Redis)
# ─────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ─────────────────────────────────────────────
# Application
# ─────────────────────────────────────────────
CYNTHERA_ENV=development
LOG_LEVEL=INFO
RULE_SET_VERSION=1.0
API_SECRET_KEY=your-secret-api-key-here
